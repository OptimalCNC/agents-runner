    "test": "bun test",
    "typecheck": "bunx tsc --noEmit"
  },
  "engines": {
    "bun": ">=1.0.0"
  },
  "dependencies": {
    "@openai/codex": "^0.114.0",
    "@openai/codex-sdk": "^0.114.0"
  },
  "devDependencies": {
    "@types/bun": "^1.2.0",
    "typescript": "^5.7.0"
  }
}
